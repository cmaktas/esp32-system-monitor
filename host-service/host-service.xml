<service>
    <id>ESP32MonitorHost</id>
    <name>ESP32 Hardware Monitor Host</name>
    <description>Reads system metrics and streams them to ESP32.</description>

    <executable>java</executable>

    <arguments>-jar "%BASE%\target\esp32-host-service.jar"</arguments>

    <env name="LHM_USERNAME" value="%LHM_USERNAME%"/>
    <env name="LHM_PASSWORD" value="%LHM_PASSWORD%"/>

    <log mode="roll">
        <logpath>%BASE%\logs\winsw-logs</logpath>
    </log>
</service>